rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isSafeUserCreate(userId) {
      return request.resource.data.ownerUid == userId
        && (!('role' in request.resource.data) || request.resource.data.role == "user");
    }

    function isSafeUserUpdate(userId) {
      return request.resource.data.ownerUid == userId
        && (
          (!('role' in resource.data) && !('role' in request.resource.data))
          || request.resource.data.role == resource.data.role
        );
    }

    match /users/{userId} {
      allow create: if isOwner(userId) && isSafeUserCreate(userId);
      allow read: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) && isSafeUserUpdate(userId);
      allow delete: if isOwner(userId);

      match /{collectionName}/{docId} {
        allow read: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && (!('ownerUid' in request.resource.data) || request.resource.data.ownerUid == userId);
      }
    }
  }
}
